  </property>
  <property name="windowTitle">
   <string>AutoPrototype</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
/* ── Global ── */
QMainWindow, QWidget#centralWidget {
    background-color: #0d0f12;
    color: #c8d4e8;
    font-family: &quot;Courier New&quot;, monospace;
    font-size: 11px;
}

/* --- Tree Widget Arrows --- */
QTreeWidget#fileTree::branch:has-children:closed {
    border-image: url(:/assets/right_arrow.svg);
    image: none;
}

QTreeWidget#fileTree::branch:has-children:open {
    border-image: url(:/assets/down_arrow.svg);
    image: none;
}

QTreeWidget#fileTree::branch:!has-children {
    border-image: none;
    image: none;
}

/* ── Menu Bar ── */
QMenuBar {
    background-color: #12151a;
    color: #5a6a82;
    border-bottom: 1px solid #252c3a;
    font-size: 11px;
    padding: 2px 4px;
}
QMenuBar::item:selected {
    background-color: #1e2330;
    color: #c8d4e8;
    border-radius: 4px;
}
QMenu {
    background-color: #12151a;
    border: 1px solid #252c3a;
    color: #c8d4e8;
}
QMenu::item:selected {
    background-color: #1e2330;
}

/* ── Status Bar ── */
QStatusBar {
    background-color: #1d4ed8;
    color: rgba(255,255,255,0.8);
    font-size: 10px;
    min-height: 22px;
}
QStatusBar::item { border: none; }

/* ── Splitter ── */
QSplitter::handle {
    background-color: #252c3a;
    width: 1px;
    height: 1px;
}

/* ── Scroll Bars ── */
QScrollBar:vertical {
    background: transparent;
    width: 5px;
    margin: 0;
}
QScrollBar::handle:vertical {
    background: #2e3849;
    border-radius: 2px;
    min-height: 20px;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }
QScrollBar:horizontal {
    background: transparent;
    height: 5px;
}
QScrollBar::handle:horizontal {
    background: #2e3849;
    border-radius: 2px;
}
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal { width: 0; }

/* ── Generic Panels ── */
QFrame#sidebarFrame {
    background-color: #12151a;
    border-right: 1px solid #252c3a;
}
QFrame#promptFrame {
    background-color: #12151a;
    border-bottom: 1px solid #252c3a;
}
QFrame#rightPanelFrame {
    background-color: #0d0f12;
    border-left: 1px solid #252c3a;
}
QFrame#dockerFrame {
    background-color: #12151a;
    border-top: 1px solid #252c3a;
}

/* ── Section Labels ── */
QLabel#sectionLabel {
    background-color: #12151a;
    color: #5a6a82;
    font-size: 10px;
    font-weight: bold;
    letter-spacing: 2px;
    padding: 6px 14px;
    border-bottom: 1px solid #252c3a;
}
QLabel#panelLabel {
    color: #5a6a82;
    font-size: 10px;
    font-weight: bold;
    letter-spacing: 2px;
}
QLabel#promptLabel {
    color: #3b82f6;
    font-size: 10px;
    font-weight: bold;
    letter-spacing: 2px;
}

/* ── Prompt TextEdit ── */
QTextEdit#promptEdit {
    background-color: #181c23;
    border: 1px solid #2e3849;
    border-radius: 6px;
    color: #e8f0fc;
    font-family: &quot;Courier New&quot;, monospace;
    font-size: 12px;
    padding: 6px 10px;
    selection-background-color: #1e3a5f;
}
QTextEdit#promptEdit:focus {
    border: 1px solid #3b82f6;
}

/* ── Log Output ── */
QPlainTextEdit#logOutput {
    background-color: #0d0f12;
    border: none;
    color: #c8d4e8;
    font-family: &quot;Courier New&quot;, monospace;
    font-size: 11px;
    padding: 8px;
    selection-background-color: #1e3a5f;
}

/* ── Tab Widget ── */
QTabWidget#logTabs::pane {
    border: none;
    background-color: #0d0f12;
}
QTabWidget#logTabs &gt; QTabBar {
    background-color: #12151a;
    qproperty-drawBase: 0;
}
QTabBar::tab {
    background-color: transparent;
    color: #5a6a82;
    border: 1px solid transparent;
    border-bottom: none;
    border-radius: 5px 5px 0 0;
    padding: 5px 14px;
    margin-right: 2px;
    font-size: 11px;
}
QTabBar::tab:selected {
    background-color: #0d0f12;
    color: #e8f0fc;
    border-color: #252c3a;
}
QTabBar::tab:hover:!selected {
    background-color: #181c23;
    color: #c8d4e8;
}

/* ── Agent List ── */
QListWidget#agentList {
    background-color: transparent;
    border: none;
    outline: none;
    padding: 6px;
}
QListWidget#agentList::item {
    background-color: transparent;
    border: 1px solid transparent;
    border-radius: 6px;
    color: #c8d4e8;
    padding: 6px 8px;
    margin-bottom: 2px;
    min-height: 36px;
}
QListWidget#agentList::item:hover {
    background-color: #181c23;
}
QListWidget#agentList::item:selected {
    background-color: #1e2330;
    border-color: #2e3849;
    color: #e8f0fc;
}

/* ── File Tree ── */
QTreeWidget#fileTree {
    background-color: transparent;
    border: none;
    color: #c8d4e8;
    font-size: 11px;
    outline: none;
}
QTreeWidget#fileTree::item {
    padding: 2px 4px;
    border-radius: 4px;
}
QTreeWidget#fileTree::item:hover {
    background-color: #181c23;
}
QTreeWidget#fileTree::item:selected {
    background-color: #1e2330;
    color: #e8f0fc;
}
QTreeWidget#fileTree::branch {
    background-color: transparent;
}

/* ── Docker Table ── */
QTableWidget#dockerTable {
    background-color: transparent;
    border: none;
    color: #c8d4e8;
    font-size: 11px;
    gridline-color: transparent;
    outline: none;
}
QTableWidget#dockerTable::item {
    padding: 4px 8px;
    border-radius: 4px;
    border-bottom: 1px solid #1e2330;
}
QTableWidget#dockerTable::item:selected {
    background-color: #1e2330;
}
QHeaderView::section {
    background-color: #12151a;
    color: #5a6a82;
    border: none;
    border-bottom: 1px solid #252c3a;
    padding: 4px 8px;
    font-size: 10px;
    letter-spacing: 1px;
}

/* ── Progress Bar ── */
QProgressBar#pipelineProgress {
    background-color: #181c23;
    border: 1px solid #252c3a;
    border-radius: 3px;
    height: 5px;
    text-align: center;
    color: transparent;
}
QProgressBar#pipelineProgress::chunk {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #3b82f6, stop:1 #06b6d4);
    border-radius: 3px;
}

/* ── Run Button ── */
QPushButton#runButton {
    background-color: #3b82f6;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    font-family: &quot;Courier New&quot;, monospace;
    font-size: 12px;
    font-weight: bold;
    letter-spacing: 2px;
    padding: 9px 16px;
}
QPushButton#runButton:hover {
    background-color: #1d4ed8;
}
QPushButton#runButton:pressed {
    background-color: #1e40af;
}

/* ── Stop Button ── */
QPushButton#stopButton {
    background-color: transparent;
    color: #5a6a82;
    border: 1px solid #252c3a;
    border-radius: 6px;
    font-size: 11px;
    padding: 7px 14px;
}
QPushButton#stopButton:hover {
    background-color: #1e2330;
    color: #ef4444;
    border-color: #ef4444;
}

/* ── Live badge label ── */
QLabel#liveBadge {
    background-color: #166534;
    color: #22c55e;
    border-radius: 3px;
    font-size: 9px;
    padding: 1px 6px;
    letter-spacing: 1px;
}
QLabel#autoscrollLabel {
    color: #5a6a82;
    font-size: 10px;
}

/* ── Progress label ── */
QLabel#progressLabel {
    color: #5a6a82;
    font-size: 10px;
    letter-spacing: 1px;
}
QLabel#progressPct {
    color: #3b82f6;
    font-size: 10px;
    font-weight: bold;
}

/* ── Table Corner Button Fix ── */
QTableCornerButton::section {
    background-color: #12151a;
    border: none;
}

QTextEdit#promptEdit:disabled {
    background-color: #12151a;
    color: #5a6a82;
    border: 1px solid #1e2330;
}

QListWidget#agentList {
    background-color: transparent;
    border: none;
    outline: none;
    padding: 6px;
}

QListWidget#agentList::item {
    background-color: transparent;
    border: none;
    padding: 0px;
    margin-bottom: 2px;
    min-height: 36px;
}

QListWidget#agentList::item:hover, 
QListWidget#agentList::item:selected {
    background-color: transparent;
}
  
/* Add this to the MainWindow stylesheet in Qt Designer */

/* --- RUN BUTTON STATES --- */
QPushButton#runButton {
    background-color: #3b82f6; color: #ffffff; border: none; border-radius: 6px;
    font-family: &quot;Courier New&quot;, monospace; font-size: 12px; font-weight: bold; 
    letter-spacing: 2px; padding: 9px 16px;
}
QPushButton#runButton:hover { background-color: #1d4ed8; }
QPushButton#runButton:pressed { background-color: #1e40af; }
QPushButton#runButton:disabled {
    background-color: transparent; color: #5a6a82; border: 1px solid #252c3a;
}

/* --- STOP BUTTON STATES --- */
QPushButton#stopButton {
    background-color: #ef4444; color: #ffffff; border: none; border-radius: 6px;
    font-size: 11px; font-weight: bold; padding: 7px 14px; letter-spacing: 1px;
}
QPushButton#stopButton:hover { background-color: #dc2626; }
QPushButton#stopButton:pressed { background-color: #b91c1c; }
QPushButton#stopButton:disabled {
    background-color: transparent; color: #5a6a82; border: 1px solid #252c3a;
}</string>
